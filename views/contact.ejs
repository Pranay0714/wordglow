<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us - AI Grammar Enhancer</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    .icon-large {
      font-size: 3rem;
      margin-bottom: 1rem;
    }
  </style>
</head>

<body class="bg-light text-dark">
  <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand text-primary fw-bold" href="/">AI Grammar Enhancer</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/">Features</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/contact">Contact</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="text-center mb-5">
      <i class="fas fa-envelope icon-large text-primary"></i>
      <h1 class="display-4 fst-italic">Contact Us</h1>
      <p class="lead text-muted">
        Have questions? We'd love to hear from you!
      </p>
    </div>

    <div class="row">
      <div class="col-md-8 mx-auto mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h2 class="card-title text-primary">
              <i class="fas fa-paper-plane me-2"></i>Send us a Message
            </h2>
            <form action="/contact" method="POST">
              <div class="mb-3">
                <label for="name" class="form-label text-dark">Full Name</label>
                <input type="text" class="form-control border-2" id="name" name="name" placeholder="Your Name" required style="border-color: #e0e0e0;">
              </div>
              <div class="mb-3">
                <label for="email" class="form-label text-dark">Email Address</label>
                <input type="email" class="form-control border-2" id="email" name="email" placeholder="your.email@example.com" required style="border-color: #e0e0e0;">
              </div>
              <div class="mb-3">
                <label for="subject" class="form-label text-dark">Subject</label>
                <input type="text" class="form-control border-2" id="subject" name="subject" placeholder="Subject of your message" required style="border-color: #e0e0e0;">
              </div>
              <div class="mb-3">
                <label for="message" class="form-label text-dark">Message</label>
                <textarea class="form-control border-2" id="message" name="message" rows="5" placeholder="Your message here..." required style="border-color: #e0e0e0;"></textarea>
              </div>
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-paper-plane me-2"></i>Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-5">
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-phone icon-large text-primary"></i>
        <h3 class="text-dark">Phone</h3>
        <p class="text-muted">+91 999999999</p>
      </div>
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-envelope icon-large text-primary"></i>
        <h3 class="text-dark">Email</h3>
        <p class="text-muted">support@wordglow.com</p>
      </div>
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-map-marker-alt icon-large text-primary"></i>
        <h3 class="text-dark">Location</h3>
        <p class="text-muted">Indore, Madhya Pradesh</p>
      </div>
    </div>
  </div>

  <footer class="text-center text-lg-start mt-5 bg-light border-top">
    <div class="container d-flex justify-content-center py-5">
      <a href="https://www.linkedin.com/in/pranay-parmar-717b8334b" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #0077b5;">
        <i class="fab fa-linkedin-in"></i>
      </a>

      <a href="https://twitter.com" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #1da1f2;">
        <i class="fab fa-twitter"></i>
      </a>
      <a href="https://github.com/pranayparmar" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #333;">
          <i class="fab fa-github" ></i>
        </a>
    </div>

    <div class="text-center text-dark p-3" style="background-color: #f8f9fa; border-top: 1px solid #dee2e6;">
      © 2026 Copyright: WordGlow
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
