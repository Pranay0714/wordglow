<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WordGlow</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>
  <style>
    .icon-large {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

  </style>
</head>

<body class="bg-light text-dark">
  <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
  <div class="container-fluid ">
    <a class="navbar-brand text-primary fw-bold" href="/">WordGlow</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto ">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#features">Features</a>
        </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact">Contact</a>
            </li>
      </ul>
    </div>
  </div>
</nav>
  <div class="container mt-5">
    <div class="text-center mb-5 py-5">
      <i class="fa-duotone fa-solid fa-robot icon-large text-primary mb-4 fs-1"></i>
      <h1 class="display-3 fw-bolder text-primary mb-3" style="letter-spacing: 3px;">WordGlow</h1>
      <p class="lead fw-semibold text-dark mb-3">
        <span id="typed-text"></span>
      </p>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h2 class="card-title text-primary">
              <i class="fa-regular fa-keyboard"></i> Input Your Text
            </h2>
            <p class="card-text text-muted">
              Enter your text below and let our AI analyze and improve it.
            </p>
            <form action="/enhance" method="POST">
              <div class="mb-3">
                <textarea class="form-control border-2" id="text" name="text" rows="5" required
                  placeholder="Type or paste your text here..." style="border-color: #e0e0e0;">
                  <%= originalText || '' %>
                </textarea>
              </div>
              <button type="submit" class="btn btn-primary">
              ✨Enhance with AI
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h2 class="card-title text-primary">
              <i class="fa-regular fa-circle-check"></i>
              AI-Corrected Output
            </h2>
            <p class="card-text text-muted">
              View your grammatically improved text below.
            </p>

            <% if(corrected) { %>
              <div class="alert alert-success" role="alert">
                <%= corrected %>
              </div>
                <% } else { %>
                  <p class="text-muted">Please enter some text to correct.</p>
                  <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-bolt icon-large text-warning"></i>
        <h3>Lightning Fast</h3>
        <p>
          Get instant grammar corrections powered by advanced AI algorithms.
        </p>
      </div>
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-brain icon-large text-info"></i>
        <h3>Intelligent Analysis</h3>
        <p>Our AI understands context and nuance for accurate corrections.</p>
      </div>
      <div class="col-md-4 text-center mb-3">
        <i class="fas fa-sync icon-large text-success"></i>
        <h3>Continuous Learning</h3>
        <p>Our AI model is constantly improving to provide better results.</p>
      </div>
    </div>

   <!-- Features -->
    <div class="row mt-5" id="features">
      <div class="col-12 mb-5">
        <h2 class="text-center display-5 mb-5">Our Features</h2>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-spell-check me-2"></i>Spelling Correction
            </h5>
            <p class="card-text text-muted">
              Automatically detect and fix spelling mistakes in your text.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-pen-fancy me-2"></i>Grammar Enhancement
            </h5>
            <p class="card-text text-muted">
              Improve sentence structure and grammatical accuracy instantly.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-lightbulb me-2"></i>Smart Suggestions
            </h5>
            <p class="card-text text-muted">
              Get intelligent suggestions to enhance clarity and readability.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-tachometer-alt me-2"></i>Real-Time Processing
            </h5>
            <p class="card-text text-muted">
              Get instant feedback and corrections as you type or paste text.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-shield-alt me-2"></i>Secure & Private
            </h5>
            <p class="card-text text-muted">
              Your text is processed securely and never stored on our servers.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-4">
        <div class="card bg-white border-0 shadow">
          <div class="card-body">
            <h5 class="card-title text-primary">
              <i class="fas fa-globe me-2"></i>Multi-Language Support
            </h5>
            <p class="card-text text-muted">
              Correct grammar in multiple languages with our advanced AI.
            </p>
          </div>
        </div>
      </div>
    </div>

    <footer class="text-center text-lg-start mt-5 bg-light border-top">
      <div class="container d-flex justify-content-center py-5">
        <a href="https://www.linkedin.com/in/pranay-parmar-717b8334b" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #0077b5;">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="https://twitter.com" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #00acee;">
          <i class="fab fa-twitter"></i>
        </a>
        <a href="https://github.com" target="_blank" class="btn btn-primary btn-lg btn-floating mx-2" style="background-color: #333;">
          <i class="fab fa-github"></i>
        </a>
      </div>

      <div class="text-center text-dark p-3" style="background-color: #f8f9fa; border-top: 1px solid #dee2e6;">
        © 2026 Copyright: WordGlow
      </div>
    </footer>

  <script>
    var typed = new Typed('#typed-text', {
      strings: [
        '👋 Welcome to WordGlow', 
        '✨ Experience the power of AI to enhance your writing with Perfect Grammar ✨',
      ],
      typeSpeed: 50,
      backSpeed: 30,
      loop: true,
      backDelay: 1500,
      startDelay: 500,
      cursorChar: '|',
      contentType: 'html'
    });
  </script>
